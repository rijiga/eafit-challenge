{
  "$id": "https://verana-labs.github.io/verifiable-trust-spec/schemas/v4/example.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Eafit Challenge Avatar Credential",
  "description": "An avatar credential schema for decentralized service identification for use in the EAFIT challenge.",
  "type": "object",
  "properties": {
    "credentialSubject": {
      "type": "object",
      "properties": {
        "name": {
          "maxLength": 256,
          "minLength": 1,
          "type": "string"
        },
        "avatar": {
          "format": "uri",
          "maxLength": 1400000,
          "pattern": "^data:image/(png|jpeg|svg\\+xml);base64,",
          "type": "string"
        }
      },
      "required": [
        "name"
      ]
    }
  }
}
