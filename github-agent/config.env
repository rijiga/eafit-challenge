# =============================================================================
# GitHub Agent VS — Configuration
# =============================================================================
#
# This file is read by the setup/start scripts and Docker Compose.
# It contains all configuration needed for the GitHub Agent service.
#
# For local testing:
#   source github-agent/config.env
#   ./github-agent/scripts/setup.sh
#
# =============================================================================

# ---------------------------------------------------------------------------
# Network (derived from branch name in GHA; set manually for local usage)
# ---------------------------------------------------------------------------
# NETWORK="testnet"

# ---------------------------------------------------------------------------
# Veranad CLI account name
# ---------------------------------------------------------------------------
USER_ACC="org-vs-admin"

# ---------------------------------------------------------------------------
# Organization — parent service
# Set to the public URL of the organization agent (K8s or local).
# The admin API is used to request Service credentials.
# ---------------------------------------------------------------------------
ORG_VS_PUBLIC_URL="${ORG_VS_PUBLIC_URL:-}"
ORG_VS_PUBLIC_URL="${ORG_VS_PUBLIC_URL%/}"
ORG_VS_ADMIN_URL="${ORG_VS_ADMIN_URL:-http://localhost:3000}"
ORG_VS_ADMIN_URL="${ORG_VS_ADMIN_URL%/}"

# ---------------------------------------------------------------------------
# VS Agent image and ports (local development)
# Use different ports than other services to avoid collision.
# ---------------------------------------------------------------------------
VS_AGENT_IMAGE="${VS_AGENT_IMAGE:-veranalabs/vs-agent:latest}"
VS_AGENT_CONTAINER_NAME="github-agent"
VS_AGENT_ADMIN_PORT="3010"
VS_AGENT_PUBLIC_PORT="3011"

# ---------------------------------------------------------------------------
# Service details
# These appear in the Service credential issued by organization.
# ---------------------------------------------------------------------------
SERVICE_NAME="GitHub Agent"
SERVICE_TYPE="AIAgent"
SERVICE_DESCRIPTION="GitHub-integrated AI agent with MCP tools"
SERVICE_LOGO_URL="https://hologram.zone/images/github.svg"
SERVICE_MIN_AGE="0"
SERVICE_TERMS="https://verana.io/terms"
SERVICE_PRIVACY="https://verana.io/privacy"

# ---------------------------------------------------------------------------
# Chatbot configuration (hologram-generic-ai-agent)
# ---------------------------------------------------------------------------
CHATBOT_IMAGE="${CHATBOT_IMAGE:-io2060/hologram-generic-ai-agent-chatbot:latest}"
CHATBOT_PORT="3003"

# LLM
LLM_PROVIDER="openai"
OPENAI_MODEL="gpt-5.4-mini"
OPENAI_API_KEY="${OPENAI_API_KEY:-}"

# RAG
RAG_PROVIDER="langchain"
RAG_DOCS_PATH="/app/rag/docs"

# Memory
AGENT_MEMORY_BACKEND="redis"
AGENT_MEMORY_WINDOW="20"

# Credential authentication
# AnonCreds credential definition ID used to authenticate users.
# This is the credDef registered by organization.
# CREDENTIAL_DEFINITION_ID="${CREDENTIAL_DEFINITION_ID:-}"
CREDENTIAL_DEFINITION_ID=""

# GitHub MCP
GITHUB_MCP_URL="https://api.githubcopilot.com/mcp/"

# MCP config encryption
MCP_CONFIG_ENCRYPTION_KEY="${MCP_CONFIG_ENCRYPTION_KEY:-}"

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_PASSWORD="${POSTGRES_PASSWORD:-changeme}"
POSTGRES_USER="github_agent_db"
POSTGRES_DB="github-agent"

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_LEVEL="info"
